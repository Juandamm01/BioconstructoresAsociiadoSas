generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Barrio {
  id     Int    @id @default(autoincrement())
  nombre String
  lat    Float
  lng    Float
  color  String
  radio  Int
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model HeroConfig {
  id         Int      @id @default(1)
  videoUrl   String   @default("/videos/hero1.mp4")
  bienvenido String   @default("Bienvenido a")
  empresa    String   @default("Bioconstructores Asociados Sas")
  slogan     String   @default("Soluciones Innovadoras Para Un Mundo Conectado.")
  updatedAt  DateTime @updatedAt
}

model PlanSchedule {
  id    Int    @id @default(1)
  dia1  String
  hora1 String
  dia2  String
  hora2 String
  dia3  String
  hora3 String
}

model PlanGroup {
  id        Int        @id @default(autoincrement())
  title     String
  subtitle  String?
  badge     String?
  isPremium Boolean    @default(false)
  order     Int        @default(0)
  items     PlanItem[]
}

model PlanItem {
  id          Int       @id @default(autoincrement())
  name        String
  price       String
  order       Int       @default(0)
  planGroupId Int
  planGroup   PlanGroup @relation(fields: [planGroupId], references: [id], onDelete: Cascade)
}

model PolicyConfig {
  id        Int      @id @default(1)
  titulo    String   @default("Políticas ISP")
  texto     String   @default("BCAS ofrece a todos sus clientes servicios normativos que garantizan seguridad digital, responsabilidad social y cumplimiento legal en")
  resaltado String   @default("Villavicencio.")
  videoUrl  String   @default("/videos/conectividad.mp4")
  b1Titulo  String   @default("Internet Sano")
  b1Texto   String   @default("Nos unimos a la campaña del Ministerio TIC para promover el uso seguro de Internet, generando conciencia sobre la prevención de la explotación infantil en entornos digitales.")
  b2Titulo  String   @default("Ley 679 de 2001")
  b2Texto   String   @default("Adoptamos medidas técnicas y administrativas para prevenir la difusión de contenido ilegal relacionado con menores de edad, implementando controles y filtros.")
  b3Titulo  String   @default("Ley 1336 de 2009")
  b3Texto   String   @default("Fortalecemos la protección de menores mediante códigos de conducta y políticas de prevención en servicios digitales para evitar la explotación sexual infantil.")
  b4Titulo  String   @default("Protección de Datos")
  b4Texto   String   @default("Garantizamos la confidencialidad de la información personal, aplicamos medidas de protección para prevenir fraude y accesos no autorizados.")
  updatedAt DateTime @updatedAt
}
